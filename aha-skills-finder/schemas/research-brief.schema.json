{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/its-How/aha-skills-finder/blob/main/aha-skills-finder/schemas/research-brief.schema.json",
  "title": "Aha Skills Finder Research Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "created",
    "target_outcome",
    "day1_answer",
    "constraints",
    "rounds"
  ],
  "properties": {
    "schema_version": {
      "const": "0.1"
    },
    "created": {
      "type": "string",
      "format": "date"
    },
    "target_outcome": {
      "type": "string",
      "minLength": 10
    },
    "lanes": {
      "type": "array",
      "description": "Optional lane-first decomposition for mixed outcomes. Use when one request contains distinct action modes that should not share one candidate pool.",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["lane_id", "target_outcome", "out_of_scope", "priority_source_families", "known_false_positives"],
        "properties": {
          "lane_id": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "target_outcome": {
            "type": "string",
            "minLength": 10
          },
          "out_of_scope": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "priority_source_families": {
            "type": "array",
            "description": "Outcome-bound source families for this lane ecosystem, not a universal mandatory checklist.",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "known_false_positives": {
            "type": "array",
            "description": "Lane-relative false positives that may still be valid in another lane.",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "why_now": {
      "type": "string",
      "minLength": 1
    },
    "day1_answer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_source", "because", "actual_outcome", "out_of_scope"],
      "properties": {
        "expected_source": { "type": "string", "minLength": 1 },
        "because": { "type": "string", "minLength": 1 },
        "actual_outcome": { "type": "string", "minLength": 10 },
        "timing_hypothesis": { "type": "string", "minLength": 1 },
        "out_of_scope": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "ecosystem", "language_or_region", "excluded_capabilities"],
      "properties": {
        "runtime": { "type": "array", "items": { "type": "string" } },
        "ecosystem": { "type": "array", "items": { "type": "string" } },
        "language_or_region": { "type": "array", "items": { "type": "string" } },
        "excluded_capabilities": { "type": "array", "items": { "type": "string" } }
      }
    },
    "source_gaps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "false_positives": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "source_url", "why_false_positive", "query_correction"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "source_url": { "type": "string", "minLength": 1 },
          "why_false_positive": { "type": "string", "minLength": 1 },
          "could_be_valid_in_lanes": {
            "type": "array",
            "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
          },
          "query_correction": { "type": "string", "minLength": 1 }
        }
      }
    },
    "rounds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["round", "purpose", "queries", "source_families", "notes"],
        "properties": {
          "round": { "enum": ["R1", "R2", "R3"] },
          "purpose": { "type": "string", "minLength": 1 },
          "queries": { "type": "array", "items": { "type": "string" } },
          "query_expansion": {
            "type": "object",
            "description": "Optional evidence for exploratory query expansion, branching, and correction. Use especially in R2 when the ecosystem may use names different from the user's seed terms.",
            "additionalProperties": false,
            "required": [
              "seed_queries",
              "expanded_queries",
              "query_branches",
              "expansion_triggers",
              "false_positive_corrections",
              "new_terms_discovered"
            ],
            "properties": {
              "seed_queries": {
                "type": "array",
                "description": "Initial terms from the user target, Day 1 answer, named runtime, or known ecosystem.",
                "items": { "type": "string", "minLength": 1 }
              },
              "expanded_queries": {
                "type": "array",
                "description": "Expanded search strings generated from synonyms, tooling verbs, runtime terms, package terms, claim terms, local-language terms, and spelling variants.",
                "items": { "type": "string", "minLength": 1 }
              },
              "query_branches": {
                "type": "array",
                "description": "Branch labels for distinct search directions such as package-registry, skill-tooling, registry-native, curated-list, local-language, or false-positive-mining.",
                "items": { "type": "string", "minLength": 1 }
              },
              "expansion_triggers": {
                "type": "array",
                "description": "Why new terms were added, for example package descriptions, README claims, false positives, registry vocabulary, local-language terms, or source gaps.",
                "items": { "type": "string", "minLength": 1 }
              },
              "false_positive_corrections": {
                "type": "array",
                "description": "Terms added or removed because a false positive showed that the original query was too broad or lane-mismatched.",
                "items": { "type": "string", "minLength": 1 }
              },
              "new_terms_discovered": {
                "type": "array",
                "description": "New ecosystem vocabulary discovered during the search. These are recall aids only, not quality or adoption signals.",
                "items": { "type": "string", "minLength": 1 }
              }
            }
          },
          "source_families": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "array", "items": { "type": "string" } }
        }
      }
    }
  }
}
